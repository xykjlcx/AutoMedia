# RSSHub 公共实例地址（可选，默认 https://rsshub.rssforever.com）
RSSHUB_BASE_URL=https://rsshub.rssforever.com

# 数据库路径（可选，默认 ./data/automedia.db）
DATABASE_PATH=./data/automedia.db

# AI API Key（可选，优先使用设置页面中的配置）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# 应用 URL（用于 Telegram 通知中的链接，部署时修改）
APP_URL=http://localhost:3000
